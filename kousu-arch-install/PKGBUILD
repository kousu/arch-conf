# Maintainer: kousu <nick@kousu.ca>

pkgname=kousu-arch-install
pkgver=0.4.2
pkgrel=1
pkgdesc="A script to install Arch unattended, with EFI booting and full disk encryption."
groups=('kousu')
arch=('any')
url="https://github.com/kousu/arch-conf"
license=('MIT')
depends=(
  arch-install-scripts
  cryptsetup
  dosfstools
  e2fsprogs
  lvm2
  parted  # for partprobe(8)
  )
source=("arch-install")
sha256sums=('dd97f2f604432a8050c69504e4b533f3bbf076b61e0ad13f07906be587498e0a')

package() {
  install -Dm 755 arch-install -t "${pkgdir}"/usr/bin
}
